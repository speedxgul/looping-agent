# Runtime
NODE_ENV=development
DRY_RUN=true
LOG_LEVEL=info
AUTONOMY_INTERVAL_MS=900000
MAX_TOOL_ROUNDS=6

# Agent identity
AGENT_NAME=SuiTreasuryAgent
AGENT_WALLET_ADDRESS=
AGENT_MISSION=Manage a Sui USDC treasury on Suilend: monitor markets and health factor, supply into best-yield allowlisted pools, borrow within safe limits, rebalance on Suilend, and post concise status updates when enabled.
AGENT_STATE_PATH=data/agent-state.json
ACTION_COOLDOWN_MS=86400000

# Sui signing key (NOT a mnemonic).
# Formats: suiprivkey1… bech32 | 0x + 64 hex chars
AGENT_SUI_PRIVATE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=https://api.openai.com/v1

# X posting
ENABLE_X_POSTING=false
X_API_BASE=https://api.x.com
# Preissued user-context token with post/write permission. No OAuth flow is implemented in v1.
X_USER_ACCESS_TOKEN=

# Sui network and execution
SUI_NETWORK=testnet
SUI_RPC_URL=
SUI_EXPLORER_TX_BASE=
SUI_USDC_COIN_TYPE=
SUI_COIN_TYPE=0x2::sui::SUI
SUI_DEFAULT_USDC_ASSET=usdc
SUI_DEFAULT_SUI_ASSET=sui

# Sui lending (Suilend primary; NAVI + Scallop read-only comparison)
ENABLE_SUI_LENDING=true
ENABLE_SUI_POSITION_CREATION=false
ENABLE_SUI_BORROW=false
# Reads (rate comparison). `ENABLE_SUILEND` also gates Suilend writes.
ENABLE_SUILEND=true
ENABLE_NAVI_READS=true
ENABLE_SCALLOP_READS=true
# Writes (supply/withdraw/borrow/repay) per protocol. NAVI/Scallop are opt-in.
ENABLE_NAVI=false
ENABLE_SCALLOP=false

# Treasury policy
MIN_IDLE_USDC_RAW=5000000
SUI_MAX_SUPPLY_AMOUNT_RAW=10000000
SUI_MAX_BORROW_AMOUNT_RAW=5000000
SUI_MIN_HEALTH_FACTOR=1.25
# Yield router: protocols the agent may route funds to (comma-separated; subset of suilend,navi,scallop).
SUI_ALLOWED_PROTOCOLS=suilend,navi,scallop
# Min supply-APR improvement (basis points) before moving already-supplied funds. Prevents churn.
SUI_REBALANCE_MIN_APR_DELTA_BPS=50
# Comma-separated coin types or shorthands (usdc, sui). Empty = all assets permitted.
SUI_ALLOWED_ASSETS=
# Comma-separated pool identifiers (reserved for future use).
SUI_ALLOWED_POOLS=

# Walrus persistence (verifiable agent state + run-report artifacts)
# file  = keep current local JSON behavior
# walrus = also upload state/report blobs to Walrus and track the latest blob id
AGENT_MEMORY_BACKEND=file
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Storage epochs to persist each blob for (testnet epoch = ~1 day).
WALRUS_STATE_EPOCHS=5
# Optional: restore/port state onto a fresh machine by pinning a known state blob id.
WALRUS_STATE_BLOB_ID=

# MemWal (Walrus Memory) semantic long-term memory
# Create an account + delegate key at https://staging.memory.walrus.xyz (testnet) and paste below.
MEMWAL_ENABLED=false
MEMWAL_ACCOUNT_ID=
# Ed25519 delegate private key in hex. Never commit this.
MEMWAL_DELEGATE_KEY=
MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_NAMESPACE=defi-agent
