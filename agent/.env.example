# Runtime
NODE_ENV=development
DRY_RUN=true
LOG_LEVEL=info
# Main loop cadence (ms) when running the single-agent autonomy loop.
AUTONOMY_INTERVAL_MS=90000
MAX_TOOL_ROUNDS=6

# Subagent supervisor: which roles this process runs.
# Comma-separated subset of: main,coordinator,rate-scout,position-risk,loop-strategist,executor,unwind-guard
SUPERVISOR_ROLES=main,rate-scout,position-risk,loop-strategist,coordinator,executor,unwind-guard
# Per-subagent loop cadence (ms).
COORDINATOR_INTERVAL_MS=300000
RATE_SCOUT_INTERVAL_MS=600000
POSITION_RISK_INTERVAL_MS=180000
LOOP_STRATEGIST_INTERVAL_MS=900000
EXECUTOR_INTERVAL_MS=60000
UNWIND_GUARD_INTERVAL_MS=60000

# Agent identity
AGENT_NAME=SuiTreasuryAgent
AGENT_WALLET_ADDRESS=
AGENT_MISSION=Manage a Sui USDC treasury on Suilend: monitor markets and health factor, supply into best-yield allowlisted pools, borrow within safe limits, rebalance on Suilend, and post concise status updates when enabled.
AGENT_STATE_PATH=data/agent-state.json
# Min time between treasury actions. Legacy alias DEPOSIT_COOLDOWN_MS is still honored as a fallback.
ACTION_COOLDOWN_MS=86400000

# Sui signing key (NOT a mnemonic). Formats: suiprivkey1… bech32 | 0x + 64 hex chars.
# This is the AGENT key — low-privilege, used by the daemon to sign capped, enclave-attested
# supplies only (it can never withdraw principal; the owner can revoke it). The OWNER key
# (full control: create/deposit/withdraw via `bun run treasury …`) is SEPARATE — pass it as
# OWNER_SUI_PRIVATE_KEY inline, or let the CLI use your Sui keystore. Never put the owner key here.
AGENT_SUI_PRIVATE_KEY=

# LLM backend — set ONE. If ANTHROPIC_API_KEY is non-empty the agent uses Anthropic's
# Messages API; otherwise it falls back to OpenAI's Responses API. Same tool loop either way.
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3
OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic (optional override)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# X posting
ENABLE_X_POSTING=false
X_API_BASE=https://api.x.com
# Preissued user-context token with post/write permission. No OAuth flow is implemented in v1.
X_USER_ACCESS_TOKEN=

# Sui network and execution
SUI_NETWORK=mainnet
SUI_RPC_URL=
SUI_EXPLORER_TX_BASE=
SUI_USDC_COIN_TYPE=
SUI_COIN_TYPE=0x2::sui::SUI
SUI_DEFAULT_USDC_ASSET=usdc
SUI_DEFAULT_SUI_ASSET=sui

# Sui lending (Suilend primary; NAVI + Scallop read-only comparison)
ENABLE_SUI_LENDING=true
ENABLE_SUI_POSITION_CREATION=true
ENABLE_SUI_BORROW=true
# Reads (rate comparison). `ENABLE_SUILEND` also gates Suilend writes.
ENABLE_SUILEND=true
ENABLE_NAVI_READS=true
ENABLE_SCALLOP_READS=true
# Writes (supply/withdraw/borrow/repay) per protocol. NAVI/Scallop are opt-in.
ENABLE_NAVI=true
ENABLE_SCALLOP=true

# Treasury policy
MIN_IDLE_USDC_RAW=1000000
SUI_MAX_SUPPLY_AMOUNT_RAW=20000000
SUI_MAX_BORROW_AMOUNT_RAW=2000000
SUI_MIN_HEALTH_FACTOR=1.25
# Yield router: protocols the agent may route funds to (comma-separated; subset of suilend,navi,scallop).
SUI_ALLOWED_PROTOCOLS=suilend,navi,scallop
# Min supply-APR improvement (basis points) before moving already-supplied funds. Prevents churn.
SUI_REBALANCE_MIN_APR_DELTA_BPS=50
# Comma-separated coin types or shorthands (usdc, sui). Empty = all assets permitted.
SUI_ALLOWED_ASSETS=
# Comma-separated pool identifiers (reserved for future use).
SUI_ALLOWED_POOLS=

# ─────────────────────────────────────────────────────────────────────────────
# Execution flow — TWO mutually-exclusive write paths, switched by TREASURY_MODE:
#   true   ATTESTED / non-custodial. Funds live in the on-chain Treasury; the agent's ONLY
#          write path is the enclave-attested `treasury_supply` (TEE signs → verified_supply_*
#          contract → custody). Wallet write tools are hidden. Fill the TREASURY_* ids below.
#          Keep the loop/subagent pipeline OFF (LOOP_STRATEGY_ENABLED=false).
#   false  NORMAL / custodial. The agent supplies its OWN WALLET funds via the SDK `lending_*`
#          tools; treasury tools are absent. Optionally enable the loop/subagent pipeline below.
# ─────────────────────────────────────────────────────────────────────────────
TREASURY_MODE=false

# --- TREASURY_MODE=true config (mainnet split-architecture deployment) ---
# Shared packages — public, stable for this deployment (see deployments/mainnet-v2.env):
TREASURY_PACKAGE_ID=0x2e069f6be4e68b6a533676122754ba9611898a431c1b0240dc4e0cc8d1cde3a4
TREASURY_MOCK_ADAPTER_PKG=0x863d31c772e494b26d9460d7f26697aa79706c882c77b382211a100e7f99ba07
TREASURY_REGISTRY_ID=0x77e41e19e5771984d3dd14f20bcadd8405baf549db995fa5ce8176520e876e29
# Per-deployment instance ids — fill from capability::create + register_enclave:
TREASURY_ID=
TREASURY_AGENT_CAP_ID=
TREASURY_ENCLAVE_OBJECT_ID=
TREASURY_ENCLAVE_URL=http://43.204.226.192:3000
# Scallop adapter + shared objects
TREASURY_SCALLOP_ADAPTER_PKG=0x308221b0a3f63a6a0cf4350e324a7765d29dc4f9bc4072d25b783ed3f5b20f68
TREASURY_SCALLOP_VERSION_ID=0x07871c4b3c847a0f674510d4978d5cf6f960452795e8ff6f189fd2088a3f6ac7
TREASURY_SCALLOP_MARKET_ID=0xa757975255146dc9686aa823b7838b507f315d704f428cbadad2f4ea061939d9
# NAVI adapter + shared objects (native USDC = asset 10)
TREASURY_NAVI_ADAPTER_PKG=0x0de89081fb15e9dbce00246448a1e1a698f21fcb723d701f3da2d8c2429621b9
TREASURY_NAVI_STORAGE_ID=0xbb4e2f4b6205c2e2a2db47aeb4f830796ec7c005f88537ee775986639bc442fe
TREASURY_NAVI_POOL_ID=0xa3582097b4c57630046c0c49a88bfc6b202a3ec0a9db5597c31765f7563755a8
TREASURY_NAVI_INCENTIVE_V2_ID=0xf87a8acb8b81d14307894d12595541a73f19933f88e1326d5be349c7a6f7559c
TREASURY_NAVI_INCENTIVE_V3_ID=0x62982dad27fb10bb314b3384d5de8d2ac2d72ab2dbeae5d801dbdb9efa816c80
TREASURY_NAVI_ASSET_ID=10
# Suilend adapter + shared objects (native USDC reserve index 7)
TREASURY_SUILEND_ADAPTER_PKG=0x2292d8d0c248a7b0246f33752e411064f88fe8575c959c1e86558436c1f55e45
TREASURY_SUILEND_MARKET_TYPE=0xf95b06141ed4a174f239417323bde3f209b972f5930d8521ea38a52aff3a6ddf::suilend::MAIN_POOL
TREASURY_SUILEND_LENDING_MARKET_ID=0x84030d26d85eaa7035084a057f2f11f701b7e2e4eda87551becbc7c97505ece1
TREASURY_SUILEND_RESERVE_INDEX=7
TREASURY_SUILEND_PYTH_PRICE_INFO_ID=0x5dec622733a204ca27f5a90d8c2fad453cc6665186fd5dff13a83d0b6c9027ab

# Walrus persistence (verifiable agent state + run-report artifacts)
# file  = keep current local JSON behavior
# walrus = also upload state/report blobs to Walrus and track the latest blob id
AGENT_MEMORY_BACKEND=file
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Storage epochs to persist each blob for (testnet epoch = ~1 day).
WALRUS_STATE_EPOCHS=5
# Optional: restore/port state onto a fresh machine by pinning a known state blob id.
WALRUS_STATE_BLOB_ID=

# MemWal (Walrus Memory) semantic long-term memory
# Create an account + delegate key at https://staging.memory.walrus.xyz (testnet) and paste below.
MEMWAL_ENABLED=false
MEMWAL_ACCOUNT_ID=
# Ed25519 delegate private key in hex. Never commit this.
MEMWAL_DELEGATE_KEY=
MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_NAMESPACE=defi-agent

# Loop (leveraged-yield) strategy — Flow 2 ONLY (TREASURY_MODE=false, agent-wallet funds,
# run via `run-supervisor`). Leave OFF for the attested treasury flow. Default off so a
# fresh template never auto-runs leverage on mainnet.
# Master switches: planning vs. on-chain execution of loop proposals.
LOOP_STRATEGY_ENABLED=false
LOOP_EXECUTION_ENABLED=false
STRATEGY_LEDGER_PATH=data/strategy-ledger.json
# Collateral/borrow legs (shorthands: usdc, sui).
LOOP_COLLATERAL_ASSET=usdc
LOOP_BORROW_ASSET=sui
# Max recursive loop depth, leverage 1 for now
LOOP_MAX_DEPTH=1
# Health-factor guardrails for the loop position.
LOOP_MIN_HEALTH_FACTOR=1.75
LOOP_CRITICAL_HEALTH_FACTOR=1.45
# USD size caps per loop.
LOOP_MAX_BORROW_USD=25
LOOP_MAX_COLLATERAL_USD=100
# Min net APR (basis points) required for a loop to be worthwhile.
LOOP_MIN_NET_APR_BPS=100
# How long a strategist proposal stays valid before expiring (ms).
LOOP_PROPOSAL_TTL_MS=300000
# How long an executor claim on a proposal is held (ms).
LOOP_EXECUTION_CLAIM_TTL_MS=120000
# Treat market/position snapshots older than this as stale (ms).
LOOP_STALE_SNAPSHOT_MS=600000
# Treat a subagent heartbeat older than this as stale (ms).
SUBAGENT_STALE_HEARTBEAT_MS=600000
# Reuse already-supplied collateral instead of supplying fresh funds.
LOOP_USE_EXISTING_COLLATERAL=true
# Fraction of available borrow capacity to use per loop.
LOOP_BORROW_CAPACITY_FRACTION=0.25
# Let the loop strategist use the LLM for proposals.
SUBAGENT_LLM_STRATEGIST_ENABLED=yes
# Allow the main agent to keep supplying while the loop strategy is enabled.
MAIN_AGENT_SUPPLY_WHEN_LOOP_ENABLED=yes
