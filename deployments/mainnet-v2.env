OWNERCAP=0x8934bc0171ddaadc9dc724a6ad191e381508f9bc609106ce9d5d79358a808254
AGENTCAP=0xd650db2922f571468ac73834c296cab06f5d4f513c6bccd2d5268e04e3fe59c9
# --- Identities (two-key model) ---
# OWNER: full control (create/deposit/withdraw, holds OwnerCap). The treasury CLI signs owner ops
#   with OWNER_SUI_PRIVATE_KEY (pass it INLINE — never store the secret here) or your Sui keystore.
# AGENT: delegated, low-privilege (holds AgentCap; only signs capped attested supplies). Its key is
#   AGENT_SUI_PRIVATE_KEY in agent/.env (used by the daemon). create() delegates to AGENT_ADDR.
OWNER_ADDR=0x19aee5602819309c0e206c1acbf97ece9ae189f68b16b4be3eed2483f981be4b
# OWNER_SUI_PRIVATE_KEY=suiprivkey1…   # optional; prefer passing inline to `bun run treasury …`
AGENT_ADDR=0xa9eba50d952acf8c7e0040a7cbc4324684b648acfa2ac87a9b7025c9451a2ad3
USDC_COIN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC

