# Single source of deployment-specific IDs for the attested-enclave flow.
# Copy to `testnet.env` (gitignore that copy), fill in YOUR values, then:
#   source deployments/testnet.env
# Scripts that read these: enclave/scripts/register-enclave.sh, agent/scripts/live-attested-supply.ts
#
# The values below are from the live testnet run on 2026-06-21 — replace them after
# any republish (PKG + Cap/Registry change) or redeploy (ENCLAVE_IP + ENCLAVE change).

# --- package (changes on every republish) ---
export PKG=0x79517b947e204f8ba6377e9e1ddc26de49145d1f55643875b79e4297b1b4396c

# --- Oyster enclave (changes on every redeploy) ---
export ENCLAVE_IP=13.207.23.212
export ENCLAVE=0x425a87be07be7a8d9a4efdc58c9a72e0052b528bfabefbcb97754d166c61cef3
export CONFIG=0x2d278d3fe0eee82ba236be0b6e6c4987d2885610b9ecca6b2a0cd025072f99b8

# --- vault objects (from create-vault; stable until you make a new vault) ---
export REGISTRY=0x4db5b390b7ed501c9e3391b8be898ac8162fa2ab94a09862783aed1afd22ff5b
export TREASURY=0x10f9730a5d11292021b9363497ab655125fe2db00b00db24bd86ead5fee4fd80
export AGENTCAP=0x6443cc6c98cca5d1eded71e6ada7329582736c39ddd3f2bcf122337bfe978cf7

# --- your wallet (gas payer / submitter) ---
export ADDR=0x2cddbffb15f99c7da8bb28e1c9f4a6483c42b4e13fee0535e242ed7e7bf435c0

# --- optional overrides ---
# export RPC=https://fullnode.testnet.sui.io:443
# export AMOUNT=50000000   # 0.05 SUI; must be <= per_tx_cap and remaining period_cap
