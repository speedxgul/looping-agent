# MAINNET deployment IDs for the attested-enclave flow (the OPS/script side).
# Copy to `mainnet.env` (gitignore that copy), fill in YOUR values, then:
#   source deployments/mainnet.env
# Scripts that read these: enclave/scripts/register-enclave.sh, agent/scripts/owner-withdraw.ts,
# agent/scripts/mainnet-*-dryrun.ts.
#
# NOTE: the AGENT PROCESS (treasury mode) reads a SEPARATE set of names (TREASURY_MODE,
# TREASURY_PACKAGE_ID, TREASURY_ID, TREASURY_AGENT_CAP_ID, TREASURY_REGISTRY_ID,
# TREASURY_ENCLAVE_OBJECT_ID, TREASURY_ENCLAVE_URL, TREASURY_SCALLOP_*, TREASURY_NAVI_*) —
# see docs/runbooks/mainnet-deploy.md Step 5. This file is for the deploy/withdraw SCRIPTS.

# --- package (from the mainnet `sui client publish`) ---
export PKG=0x…

# --- Oyster enclave on mainnet (changes on every redeploy) ---
export ENCLAVE_IP=…
export ENCLAVE=0x…          # the attested Enclave<DECISION>
export CONFIG=0x…           # the EnclaveConfig<DECISION>

# --- vault objects (from `capability::create` on mainnet) ---
export REGISTRY=0x…         # the shared DecisionRegistry (from publish)
export TREASURY=0x…         # the Treasury<USDC>
export AGENTCAP=0x…         # AgentCap (delegated to the agent)
export OWNERCAP=0x…         # OwnerCap (you — needed for owner-withdraw.ts)

# --- your wallet (gas payer / submitter / owner) ---
export ADDR=0x…
export USDC_COIN_TYPE=0x…::usdc::USDC   # the real mainnet USDC type you funded the vault with

# --- Scallop (the recommended first round-trip; resolve LIVE from the SDK — ids drift) ---
#   const a = await new Scallop({networkType:'mainnet'}).getScallopAddress()
#   -> a.get('core.object') (package), a.get('core.version'), a.get('core.market')
export SCALLOP_PACKAGE=0x…
export SCALLOP_VERSION=0x…
export SCALLOP_MARKET=0x…

# --- NAVI (second round-trip; the SDK auto-resolves Storage/Pool/Incentive on deposit,
#     but the OWNER WITHDRAW needs these explicitly + an oracle refresh prepended) ---
export NAVI_STORAGE=0x…
export NAVI_POOL=0x…
export NAVI_INCENTIVE_V2=0x…
export NAVI_INCENTIVE_V3=0x…
export NAVI_ORACLE=0x…
export NAVI_ASSET=…         # the asset/reserve index for USDC (u8)

# --- optional overrides ---
# export RPC=https://fullnode.mainnet.sui.io:443
# export AMOUNT=…            # raw units; must be <= per_tx_cap and remaining period_cap
