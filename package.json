{
  "name": "treasury-agent",
  "private": true,
  "description": "Monorepo root — delegates to agent/ (TS) and move/ (Sui Move). No workspace yet; add when web/ lands.",
  "scripts": {
    "setup": "cd agent && bun install",
    "dev": "cd agent && bun run run:once",
    "doctor": "cd agent && bun run doctor",
    "test": "cd agent && bun test",
    "typecheck": "cd agent && bun run typecheck",
    "check": "cd agent && bun run check",
    "check:fix": "cd agent && bun run check:fix",
    "gen:decision-vectors": "cd agent && bun run gen:decision-vectors",
    "move:build": "cd move && sui move build",
    "move:test": "cd move && sui move test"
  }
}
