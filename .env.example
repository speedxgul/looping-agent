# Runtime
NODE_ENV=development
DRY_RUN=true
LOG_LEVEL=info
AUTONOMY_INTERVAL_MS=900000
MAX_TOOL_ROUNDS=6

# Agent identity
AGENT_NAME=StablecoinTreasuryAgent
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_MISSION=Monitor my Base wallet, explain Fluid lending state, find safe swap opportunities, and post concise status updates only when enabled.
AGENT_STATE_PATH=data/agent-state.json
DEPOSIT_COOLDOWN_MS=86400000
# 32-byte private key for AGENT_WALLET_ADDRESS (NOT a mnemonic).
# Formats: 0x + 64 hex chars | 32 comma-separated hex bytes | 32 comma-separated decimals 0-255
# Derive from seed: bun derive-key.ts "word1 ... word12"
AGENT_PRIVATE_KEY=
ACCOUNT_MODE=eoa

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=https://api.openai.com/v1

# MoltX Social
MOLTX_API_BASE=https://moltx.io/v1

# X posting
ENABLE_X_POSTING=false
X_API_BASE=https://api.x.com
# Preissued user-context token with post/write permission. No OAuth flow is implemented in v1.
X_USER_ACCESS_TOKEN=

# MoltX Swap
MOLTX_SWAP_BASE=https://swap.moltx.io
ENABLE_SWAP_QUOTES=true
ENABLE_AUTONOMOUS_SWAPS=false
QUOTE_NETWORK=base
QUOTE_SELL_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
QUOTE_BUY_TOKEN=0x4200000000000000000000000000000000000006
QUOTE_SELL_AMOUNT=1000000
MAX_SLIPPAGE_PERCENT=0.5
MAX_PRICE_IMPACT_PERCENT=1

# Fluid lending
MOLTX_DEFI_BASE=https://defi.moltx.io
ENABLE_FLUID_LENDING=true
ENABLE_FLUID_POSITION_CREATION=false
MIN_IDLE_USDC_RAW=5000000
FLUID_MAX_SUPPLY_AMOUNT_RAW=10000000
# Comma-separated fToken addresses the agent may supply into (empty = none allowed).
# Discovered Base markets: fWETH 0x9272D6153133175175Bc276512B2336BE3931CE9,
#   fUSDC 0xf42f5795D9ac7e9D757dB633D693cD548Cfd9169,
#   fwstETH 0x896E39f0E9af61ECA9dD2938E14543506ef2c2b5,
#   fEURC 0x1943FA26360f038230442525Cf1B9125b5DCB401,
#   fsUSDS 0xf62e339f21d8018940f188F6987Bcdf02A849619,
#   fGHO 0x8DdbfFA3CFda2355a23d6B11105AC624BDbE3631
FLUID_ALLOWED_FTOKENS=
# Required for create_fluid_position with market=usdc
FLUID_USDC_FTOKEN=0xf42f5795D9ac7e9D757dB633D693cD548Cfd9169
FLUID_WETH_FTOKEN=0x9272D6153133175175Bc276512B2336BE3931CE9

# EVM execution
BASE_RPC_URL=
SMART_ACCOUNT_BUNDLER_URL=
SMART_ACCOUNT_USE_PAYMASTER=false

# Walrus persistence (verifiable agent state + run-report artifacts)
# file  = keep current local JSON behavior
# walrus = also upload state/report blobs to Walrus and track the latest blob id
AGENT_MEMORY_BACKEND=file
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Storage epochs to persist each blob for (testnet epoch = ~1 day).
WALRUS_STATE_EPOCHS=5
# Optional: restore/port state onto a fresh machine by pinning a known state blob id.
WALRUS_STATE_BLOB_ID=

# MemWal (Walrus Memory) semantic long-term memory
# Create an account + delegate key at https://staging.memory.walrus.xyz (testnet) and paste below.
MEMWAL_ENABLED=false
MEMWAL_ACCOUNT_ID=
# Ed25519 delegate private key in hex. Never commit this.
MEMWAL_DELEGATE_KEY=
MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_NAMESPACE=defi-agent
